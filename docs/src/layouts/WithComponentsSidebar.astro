---
import { getAllComponentsForShowcase, getTextTag, getMarkdown } from '../_data/getLitComponentDetails.ts';
interface Props {
  componentDetails: any;
  title?: string;
}

const {componentDetails, title} = Astro.props;
import Layout from './WithSidebar.astro';
import Footer from '../components/Footer.astro';

const componentEntries = getAllComponentsForShowcase();

const pageTitle = getTextTag(componentDetails, 'label') || title;
const description = getTextTag(componentDetails, 'summary');
const wip = getTextTag(componentDetails, 'wip');

const sidebarItems = [];
sidebarItems.push({
  label: 'Components Overview',
  href: '/components/'
})
sidebarItems.push(...componentEntries.map((component) => {
  return {
    label: getTextTag(component, 'label'),
    href: `/components/${getTextTag(component, 'rawTag')}/`,
  };
}));
---

<Layout title={pageTitle} description={description} sidebarItems={sidebarItems}>


  <div class='main-content'>
    <wc-container class='page-wrapper'>

      <div class='comp-header'>
        <h1 class='heading-scrollable text-display'>{pageTitle}</h1>
        { wip ? <wc-tag color='red'>Work in progress</wc-tag>  : '' }
      </div>

      <div class='component-description'>
           <div class='text-title-large'
             set:html={getTextTag(componentDetails, 'overview') ? getMarkdown(componentDetails, 'overview') : getTextTag(componentDetails, 'summary')}>

        </div>
      </div>

      <slot/>

    </wc-container>

    <div class='footer container'>
      <pc-divider></pc-divider>
      <Footer/>
    </div>
  </div>


</Layout>
