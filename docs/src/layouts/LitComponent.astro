---
import { getTextTag, getMarkdown } from '../_data/getLitComponentDetails.ts';
interface Props {
  componentDetails: any;
}

import customElementsJSDocs from '../_data/custom-elements-jsdocs.json';

const {componentDetails} = Astro.props;
import Layout from './Default.astro';
import '../styles/component.layout.scss';
import Footer from '../components/Footer.astro';

const title = getTextTag(componentDetails, 'label');
const rawTag = getTextTag(componentDetails, 'rawTag');
const description = getTextTag(componentDetails, 'summary');
const wip = getTextTag(componentDetails, 'wip');
---

<Layout title={title} description={description} classes='surface'>

  <div class='sidenav m-hide surface' id="component-page">

    <div class='sidenav-components'>

      <wc-sidebar-menu layer='01' selected-item={title}>
        <wc-sidebar-menu-item label="Overview" href='/components'></wc-sidebar-menu-item>

        {
            customElementsJSDocs.map((component) => {
              if (component.parentRawTag) {
                return;
              }
              return <wc-sidebar-menu-item label={component?.label}
                                               href={`/components/${component?.rawTag}/`}></wc-sidebar-menu-item>
            })
        }
      </wc-sidebar-menu>

    </div>

  </div>
  <div class='main-content'>
    <wc-container class='page-wrapper'>

      <div class='comp-header'>
        <h1 class='heading-scrollable text-display'>{title} {wip}</h1>
        { wip ? <wc-tag color='red'>Work in progress</wc-tag>  : '' }
      </div>

      <div class='component-description'>
           <div class='text-title-large'
             set:html={getTextTag(componentDetails, 'overview') ? getMarkdown(componentDetails, 'overview') : getTextTag(componentDetails, 'summary')}>

        </div>
      </div>

      <slot/>

    </wc-container>

    <div class='footer container'>
      <pc-divider></pc-divider>
      <Footer/>
    </div>
  </div>


</Layout>
