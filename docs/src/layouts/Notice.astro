---
import Layout from './Default.astro';
import '../styles/layout/notice.scss';
const { title, description, keywords} = Astro.props.frontmatter;
---
<Layout title={title} description={description} keywords={keywords}>

  <main>
    <wc-container size="lg">

      <article class="markdown">
        <slot />
      </article>


      <wc-button class='back-to-home' type="secondary" icon-align='start' href='/#'>
        <wc-icon name='arrow_left_alt' slot='icon'></wc-icon>
        Back to home
      </wc-button>
    </wc-container>
  </main>

</Layout>
