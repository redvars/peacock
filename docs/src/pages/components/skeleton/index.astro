---
import Layout from '../../../layouts/LitComponent.astro';
import { getComponentDetails, getTextTag } from '../../../_data/getLitComponentDetails.ts';
import ApiPanel from '../../../components/LitApiPanel.astro';
import OverviewPanel from '../../../components/OverviewPanel.astro';

import UsageSection from './_sections/Usage.astro';
import SizesSection from './_sections/Sizes.astro';
import ShapesSection from './_sections/Shapes.astro';

const componentDetails = getComponentDetails('skeleton');

const title = getTextTag(componentDetails, 'label');

const sections = [
  {
    'title': 'Usage',
    'Component': UsageSection,
  }, {
    'title': 'Sizes',
    'Component': SizesSection,
  }, {
    'title': 'Shapes',
    'Component': ShapesSection,
  }];
---
<Layout componentDetails={componentDetails}>
  <wc-tab-group class='page-tabs'>
    <wc-tabs>
      <wc-tab selected='true'>Overview</wc-tab>
      <wc-tab>API</wc-tab>
    </wc-tabs>
    <wc-tab-panel>
      <OverviewPanel sections={sections} title={title} />
    </wc-tab-panel>
    <wc-tab-panel>
      <ApiPanel componentDetails={componentDetails} />
    </wc-tab-panel>
  </wc-tab-group>
</Layout>