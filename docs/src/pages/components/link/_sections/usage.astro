  </a>
</DemoComponentCard>

<DemoComponentCard lang={'html'}>
  <wc-link class='text-body' href='https://github.com/goatui/components' target='_blank'>
    Github
    <wc-icon name='arrow_right_alt'></wc-icon>
  </wc-link>
</DemoComponentCard>

<DemoComponentCard lang={'html'}>
  <p>
    Some sentence
    <a class='link inline' href='#'>Inline link</a>
    in-between
  </p>
</DemoComponentCard>

