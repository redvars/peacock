---
export const title = 'Usage';
export const order = 100;
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
import { REPO_URL } from '../../../../siteconfig';
---

<p>Here are predefined variants of link, each serving its own semantic purpose.</p>

<DemoComponentCard lang={'html'}>
  <a class='link text-body' href={REPO_URL} target='_blank'>
    Github
    <wc-icon name='arrow_right_alt'></wc-icon>
  </a>
</DemoComponentCard>

<DemoComponentCard lang={'html'}>
  <wc-link class='text-body' href={REPO_URL} target='_blank'>
    Github
    <wc-icon name='arrow_right_alt'></wc-icon>
  </wc-link>
</DemoComponentCard>

<DemoComponentCard lang={'html'}>
  <p>
    Some sentence
    <a class='link inline' href='#'>Inline link</a>
    in-between
  </p>
</DemoComponentCard>

