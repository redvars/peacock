---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
---

<pc-text type='heading' heading-size='3'>Disabled</pc-text>
<p class='text-body-large'
>Make input look inactive by adding the disabled <code class='highlighter-rouge' data-lang='html'>boolean</code>
  attribute to any
  <code class='highlighter-rouge' data-lang='html'>&lt;input&gt;</code> element.
</p>

<HighlighterCard lang={'html'}>
  <wc-switch disabled>Disabled toggle</wc-switch>
  <wc-switch disabled value='true'>Disabled toggle</wc-switch>
</HighlighterCard>
