---
export const title = 'States';
export const order = 300;
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<h3>Disabled</h3>
<p>Make input look inactive by adding the disabled <code>boolean</code> attribute to any
  <code>&lt;button&gt;</code> element.
</p>

<DemoComponentCard lang={'html'}>
  <wc-input disabled>
    <wc-icon slot='start' class='inherit' name='mail'></wc-icon>
    <span slot='end'>@example.com</span>
  </wc-input>
</DemoComponentCard>

<br />

<h3>Readonly</h3>
<p>Make input look inactive by adding the disabled <code>boolean</code> attribute to any
  <code>&lt;button&gt;</code> element.
</p>

<DemoComponentCard lang={'html'}>
  <wc-input readonly='true'>
    <wc-icon slot='start' class='inherit' name='mail'></wc-icon>
    <span slot='end'>@example.com</span>
  </wc-input>
</DemoComponentCard>

<br />

<h3>Status</h3>
<DemoComponentCard lang={'html'}>
  <wc-input label='City' error error-text='Please provide a valid city' value='America'></wc-input>
  <wc-input label='City' warning warning-text='Please provide a valid city' value='America'></wc-input>
</DemoComponentCard>
