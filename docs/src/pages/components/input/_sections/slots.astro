---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<p class='text-body-large'>Fancy larger or smaller input? Add size attribute for additional sizes.</p>
<DemoComponentCard lang={'html'}>

    <input-field label='Email' type='text' size='lg'>
      <base-icon slot='start' name='mail'></base-icon>
      <div slot='end'>@example.com</div>
    </input-field>

    <input-field type='text' label='Card Number'>
      <base-icon slot='start' name='credit_card'></base-icon>
      <circular-progress slot='end' indeterminate></circular-progress>
    </input-field>

</DemoComponentCard>
