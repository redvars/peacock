---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---


<style is:inline>
  #slider {
    padding: 0 3rem;
  }
</style>

<DemoComponentCard lang={'html'}>
  <wc-slider id='slider' value='100' step='5'></pc-slider>
</DemoComponentCard>

<script is:inline>
  const slider = document.querySelector('#slider');
  slider.addEventListener('goat-slider--change', e => {
    myConsole.warn(JSON.stringify(e.detail, null, 4), e.type);
  });
  slider.addEventListener('goat-slider--input', e => {
    myConsole.log(JSON.stringify(e.detail, null, 4), e.type);
  });
</script>
