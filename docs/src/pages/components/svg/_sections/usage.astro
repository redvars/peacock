---
export const title = 'Usage';
export const order = 100;
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---

<p>Provide a URL to any SVG file via the <code>src</code> attribute. The SVG is fetched, sanitized, and rendered inline. Use <code>image-title</code> for accessible alt text and <code>preview</code> to enable a click-to-enlarge lightbox.</p>

<DemoComponentCard lang={'html'} inline>
  <wc-svg
    src='https://icons.getbootstrap.com/assets/icons/bug.svg'
    image-title='Bug icon'
    style='--svg-size: 2rem;'
  ></wc-svg>
  <wc-svg
    src='https://icons.getbootstrap.com/assets/icons/heart-fill.svg'
    image-title='Heart icon'
    style='--svg-size: 2rem; --svg-color: var(--color-error);'
    preview
  ></wc-svg>
</DemoComponentCard>
