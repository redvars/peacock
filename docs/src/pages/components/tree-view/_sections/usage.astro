---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
---
<HighlighterCard lang={'html'}>
  <wc-tree-view id='tree-view' style='width: 300px;' selected-node='Blockchain'>
    <wc-tree-node label='Artificial intelligence'></wc-tree-node>
    <wc-tree-node label='Blockchain'></wc-tree-node>
    <wc-tree-node label='Cloud computing'>
      <wc-tree-node label='Containers'></wc-tree-node>
      <wc-tree-node label='Databases'></wc-tree-node>
    </wc-tree-node>
  </wc-tree-view>
</HighlighterCard>

<script is:inline>
  const treeView = document.querySelector('#tree-view');
  treeView.addEventListener('tree-node--click', function(evt) {
    myConsole.log(JSON.stringify(evt.detail.value, null, 4),  evt.type);
  });
</script>
