---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---

<p class='text-body-large'>Here are several predefined button styles, each serving its own semantic purpose.</p>

<style is:inline>
  .button-demo-title {
    margin-block-end: 1rem;
  }


  .button-demo-area {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    gap: 1rem;
    height: 100%;
  }
</style>

<DemoComponentCard lang={'html'} inline>

<div class='button-demo-container'>
  <h3 class='text-title button-demo-title'>Default Variants</h3>
  <div class='button-demo-area'>
    <wc-button variant='elevated'>Elevated</wc-button>
    <wc-button>Filled / Default</wc-button>
    <wc-button variant='tonal'>Tonal</wc-button>
    <wc-button variant='outlined'>Outlined</wc-button>
    <wc-button variant='text'>Text</wc-button>
    <wc-button variant='neo'>Neo-Brutalism</wc-button>
  </div>
</div>



  <div class='button-demo-container'>
   <h3 class='text-title button-demo-title'>Toggle Variants - Unselected</h3>
   <div class='button-demo-area'>
   <wc-button variant='elevated' toggle>Elevated</wc-button>
   <wc-button toggle selected>Filled / Default</wc-button>
   <wc-button variant='tonal' toggle>Tonal</wc-button>
   <wc-button variant='outlined' toggle>Outlined</wc-button>
   </div>
  </div>

  <div class='button-demo-container'>
   <h3 class='text-title button-demo-title'>Toggle Variants - Selected</h3>
   <div class='button-demo-area'>
    <wc-button variant='elevated' toggle selected>Elevated</wc-button>
    <wc-button toggle selected>Filled / Default</wc-button>
    <wc-button variant='tonal' toggle selected>Tonal</wc-button>
    <wc-button variant='outlined' toggle selected>Outlined</wc-button>
   </div>
  </div>

</div>

</DemoComponentCard>


<DemoComponentCard lang={'html'}>
  <wc-button block>Block</wc-button>
</DemoComponentCard>

<br/>

<style is:inline>
  strong {
    font-weight: bold;
  }
</style>

<p class='text-body-large'>The <code-highlighter inline="true">type</code-highlighter> property property serves as <strong>syntactic sugar</strong>, allowing you to quickly define a button's visual identity without manually configuring individual style attributes.</p>
<p class='text-body-large'><code-highlighter inline="true">type="primary"</code-highlighter>: A shorthand for applying both the <strong>filled</strong> variant and the <strong>primary</strong> brand color simultaneously.</p>

<DemoComponentCard lang={'html'} inline>
  <wc-button type='primary'>Primary</wc-button>
  <wc-button type='secondary'>Secondary</wc-button>
  <wc-button type='tertiary'>Tertiary</wc-button>
  <wc-button type='danger'>Danger</wc-button>
</DemoComponentCard>
