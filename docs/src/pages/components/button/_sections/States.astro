---
export const title = 'States';
export const order = 600;
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<h3>Selected</h3>

<p>Make buttons look active by adding the selected <code>boolean</code> attribute to any
  <code>&lt;button&gt;</code> element.
</p>

<DemoComponentCard lang={'html'}>
  <wc-button selected>Primary</wc-button>
</DemoComponentCard>

<br />

<h3>Disabled</h3>
<p>Make buttons look inactive by adding the disabled <code>boolean</code> attribute to
  any <code>&lt;button&gt;</code> element.
</p>

<DemoComponentCard lang={'html'} inline>
  <wc-button variant='elevated' disabled><wc-icon name='home' slot='icon'/>Elevated</wc-button>
  <wc-button disabled>Filled</wc-button>
  <wc-button variant='tonal' disabled>Tonal</wc-button>
  <wc-button variant='outlined' disabled>Outline</wc-button>
  <wc-button variant='text' disabled>Ghost</wc-button>
</DemoComponentCard>

<br />

<h4 class='text-title'>Soft disabled</h4>
<p>Make buttons look inactive by adding the soft-disabled <code>boolean</code> attribute to
  any <code>&lt;button&gt;</code> element. But the button is still be focusable for accessibility reasons.
</p>


<DemoComponentCard lang={'html'}>
  <wc-button soft-disabled>Elevated</wc-button>
</DemoComponentCard>

<br />

<h4 class='text-title'>Skeleton</h4>
<p>Use the skeleton state to display a button while its content is loading.</p>
<DemoComponentCard lang={'html'}>
  <wc-button skeleton>Elevated</wc-button>
</DemoComponentCard>
