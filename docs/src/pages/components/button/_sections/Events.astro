---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import Highlighter from '../../../../components/Highlighter.astro';
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<DemoComponentCard lang='html'>
  <wc-button id='click-me-btn'>Click me</wc-button>
  <wc-button disabled id='disabled-btn'>Disabled Button</wc-button>

  <script is:inline>
    document.querySelector('#click-me-btn').addEventListener('click', (event) => {
      myConsole.log('IconButton clicked', '<wc-button>');
    });
    document.querySelector('#disabled-btn').addEventListener('click', (event) => {
      myConsole.log('IconButton clicked', '<wc-button disabled>');
    });
  </script>
</DemoComponentCard>
