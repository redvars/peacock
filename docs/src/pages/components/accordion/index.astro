---
import Layout from '../../../layouts/WithComponentsSidebar.astro';
import Article from '../../../components/Article.astro';
import { getComponentDetails, getMarkdown, getTextTag } from '../../../_data/getLitComponentDetails.ts';

const componentDetails = getComponentDetails('accordion');
const title = getTextTag(componentDetails, 'label');
const description = getTextTag(componentDetails, 'description');
const summary = getMarkdown(componentDetails, 'summary');

const astroModules = import.meta.glob('./_sections/*.astro', { eager: true });
const mdxModules = import.meta.glob('./_sections/*.mdx', { eager: true });

const sections = Object.entries({ ...astroModules, ...mdxModules })
  .map(([path, module]) => {
    const fileName = path.split('/').pop() || '';
    const name = fileName.replace(/\.(astro|mdx)$/, '');
    return {
      title: (module as any).title || name,
      order: (module as any).order || 999,
      component: (module as any).default,
    };
  })
  .sort((a, b) => a.order - b.order);
---



<Layout title={title} description={description}>

  <style is:inline>
    wc-accordion {
      width: 20rem;
    }
  </style>

  <Article title={title} description={summary || description} sections={sections}>

  </Article>
</Layout>
