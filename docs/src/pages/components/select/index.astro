---
import Layout from '../../../layouts/LitComponent.astro';
import { getComponentDetails } from '../../../_data/getLitComponentDetails.ts';
import ApiPanel from '../../../components/LitApiPanel.astro';
import OverviewPanel from '../../../components/OverviewPanel.astro';
const componentDetails = getComponentDetails('select');

import UsageSection from './_sections/usage.astro';
import SearchSection from './_sections/search.astro';
import ManagedSearchSection from './_sections/managed.astro';
import MultiSelectSection from './_sections/multi-select.astro';

const sections = [{
  'title': 'Usage',
  'Component': UsageSection,
}, {
  'title': 'Search / Typeahead',
  'Component': SearchSection,
}, {
  'title': 'Managed Search',
  'Component': ManagedSearchSection,
}, {
  'title': 'Multi Select',
  'Component': MultiSelectSection,
}];
---

<Layout componentDetails={componentDetails}>
  <wc-tab-group class='page-tabs'>
    <wc-tabs>
      <wc-tab selected='true'>Overview</wc-tab>
      <wc-tab>API</wc-tab>
    </wc-tabs>
    <wc-tab-panel>
      <OverviewPanel sections={sections} />
    </wc-tab-panel>
    <wc-tab-panel>
      <ApiPanel componentDetails={componentDetails} />
    </wc-tab-panel>
  </wc-tab-group>
</Layout>
