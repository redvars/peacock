---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<p class='text-body-large'>
  Place <code>&lt;wc-option&gt;</code> elements directly inside <code>&lt;wc-select&gt;</code> to
  declare options in HTML. Each option requires a <code>value</code> attribute; the text content
  becomes the visible label.
</p>

<DemoComponentCard lang={'html'}>
  <wc-select
    label="Country"
    placeholder="Choose a country..."
    style="width: 22rem"
  >
    <wc-option value="">None</wc-option>
    <wc-option value="us">United States</wc-option>
    <wc-option value="gb">United Kingdom</wc-option>
    <wc-option value="de">Germany</wc-option>
    <wc-option value="fr">France</wc-option>
    <wc-option value="jp">Japan</wc-option>
  </wc-select>
</DemoComponentCard>

<p class='text-body-large'>
  Add an <code>icon</code> attribute with a Material Symbol name to show a leading icon.
</p>

<DemoComponentCard lang={'html'}>
  <wc-select
    label="Priority"
    placeholder="Set priority..."
    style="width: 20rem"
  >
    <wc-option value="high" icon="arrow_upward">High</wc-option>
    <wc-option value="medium" icon="remove">Medium</wc-option>
    <wc-option value="low" icon="arrow_downward">Low</wc-option>
  </wc-select>
</DemoComponentCard>

<p class='text-body-large'>
  Disable individual options with the <code>disabled</code> attribute.
</p>

<DemoComponentCard lang={'html'}>
  <wc-select
    label="Plan"
    placeholder="Choose a plan..."
    style="width: 20rem"
  >
    <wc-option value="free">Free</wc-option>
    <wc-option value="pro">Pro</wc-option>
    <wc-option value="enterprise" disabled>Enterprise (contact sales)</wc-option>
  </wc-select>
</DemoComponentCard>
