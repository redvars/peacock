---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<p class='text-body-large'>A basic single-select dropdown backed by an options array.</p>

<DemoComponentCard lang={'html'}>
  <wc-select
    id="basic-select"
    label="Fruit"
    placeholder="Pick a fruit..."
    clearable
    style="width: 20rem"
  ></wc-select>

  <script is:inline>
    const sel = document.getElementById('basic-select');
    sel.options = [
      { label: 'Apple', value: 'apple' },
      { label: 'Banana', value: 'banana' },
      { label: 'Cherry', value: 'cherry' },
      { label: 'Dragonfruit', value: 'dragonfruit' },
      { label: 'Elderberry', value: 'elderberry' },
    ];
    sel.addEventListener('change', function (evt) {
      console.log('change', evt.detail);
    });
  </script>
</DemoComponentCard>

<DemoComponentCard lang={'html'}>
  <wc-select
    id="outlined-select"
    label="Fruit"
    placeholder="Pick a fruit..."
    variant="outlined"
    clearable
    style="width: 20rem"
  ></wc-select>

  <script is:inline>
    const outlinedSel = document.getElementById('outlined-select');
    outlinedSel.options = [
      { label: 'Apple', value: 'apple' },
      { label: 'Banana', value: 'banana' },
      { label: 'Cherry', value: 'cherry' },
    ];
  </script>
</DemoComponentCard>

<DemoComponentCard lang={'html'}>
  <wc-select
    id="icons-select"
    label="Action"
    placeholder="Choose an action..."
    clearable
    style="width: 20rem"
  ></wc-select>

  <script is:inline>
    const iconsSel = document.getElementById('icons-select');
    iconsSel.options = [
      { label: 'New file', value: 'new', icon: 'add' },
      { label: 'Save', value: 'save', icon: 'save' },
      { label: 'Delete', value: 'delete', icon: 'delete' },
    ];
  </script>
</DemoComponentCard>
