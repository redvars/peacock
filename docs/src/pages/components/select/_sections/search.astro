---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<p class='text-body-large'>Use <code>search="contains"</code> for client-side typeahead filtering.</p>

<DemoComponentCard lang={'html'}>
  <wc-select
    id="search-select"
    label="Action"
    placeholder="Type to filter..."
    search="contains"
    clearable
    style="width: 20rem"
  ></wc-select>

  <script is:inline>
    const searchSel = document.getElementById('search-select');
    searchSel.items = [
      { label: 'New file', value: 'new', icon: 'add' },
      { label: 'Save', value: 'save', icon: 'save' },
      { label: 'Save As', value: 'save-as' },
      { label: 'Nadine Brooks', value: 'nadine' },
      { label: 'Laura Ballard', value: 'laura' },
      { label: 'Jack Thompson', value: 'jack' },
    ];
    searchSel.addEventListener('change', function (evt) {
      console.log('change', evt.detail);
    });
  </script>
</DemoComponentCard>
