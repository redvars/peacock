---
export const title = 'Usage';
export const order = 100;
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---



<DemoComponentCard lang={'html'}>

  <style is:inline>
  .footer-simple {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 5rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-outline-variant);
    gap: .5rem;
    padding-block: 1rem;
    flex-wrap: wrap;
  }
  .text-body-large {
    margin-block-end: 0 !important;
  }
</style>

  <div class="footer-simple">
    <div>
      &copy; {new Date().getFullYear()} Peacock.
    </div>
    <div>
      All rights reserved.
    </div>
  </div>

</DemoComponentCard>
