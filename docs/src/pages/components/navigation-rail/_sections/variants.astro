---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---

<h3>Alignment</h3>
<p>Items can be aligned to the top, center (default), or bottom of the rail.</p>

<DemoComponentCard lang={'html'}>
  <div style="display: flex; gap: 1rem; height: 400px;">
    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
      <span class="text-label" style="font-size: 0.75rem; color: var(--color-on-surface-variant);">Top</span>
      <wc-navigation-rail alignment="top" style="height: 100%; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
        <wc-navigation-rail-item active>
          <wc-icon slot="icon" name="home"></wc-icon>
          Home
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="search"></wc-icon>
          Search
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="settings"></wc-icon>
          Settings
        </wc-navigation-rail-item>
      </wc-navigation-rail>
    </div>

    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
      <span class="text-label" style="font-size: 0.75rem; color: var(--color-on-surface-variant);">Center</span>
      <wc-navigation-rail alignment="center" style="height: 100%; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
        <wc-navigation-rail-item active>
          <wc-icon slot="icon" name="home"></wc-icon>
          Home
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="search"></wc-icon>
          Search
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="settings"></wc-icon>
          Settings
        </wc-navigation-rail-item>
      </wc-navigation-rail>
    </div>

    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
      <span class="text-label" style="font-size: 0.75rem; color: var(--color-on-surface-variant);">Bottom</span>
      <wc-navigation-rail alignment="bottom" style="height: 100%; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
        <wc-navigation-rail-item active>
          <wc-icon slot="icon" name="home"></wc-icon>
          Home
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="search"></wc-icon>
          Search
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="settings"></wc-icon>
          Settings
        </wc-navigation-rail-item>
      </wc-navigation-rail>
    </div>
  </div>
</DemoComponentCard>

<h3>With FAB Header</h3>
<p>A FAB or other header content can be placed in the header slot above the items.</p>

<DemoComponentCard lang={'html'}>
  <wc-navigation-rail alignment="top" style="height: 400px; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
    <wc-fab slot="header" style="margin-bottom: 0.5rem;"><wc-icon name="edit"></wc-icon></wc-fab>
    <wc-navigation-rail-item active>
      <wc-icon slot="icon" name="inbox"></wc-icon>
      Inbox
    </wc-navigation-rail-item>
    <wc-navigation-rail-item>
      <wc-icon slot="icon" name="send"></wc-icon>
      Outbox
    </wc-navigation-rail-item>
    <wc-navigation-rail-item>
      <wc-icon slot="icon" name="drafts"></wc-icon>
      Drafts
    </wc-navigation-rail-item>
    <wc-navigation-rail-item disabled>
      <wc-icon slot="icon" name="delete"></wc-icon>
      Trash
    </wc-navigation-rail-item>
  </wc-navigation-rail>
</DemoComponentCard>

<h3>Modes</h3>
<p>Use expanded mode to show labels and collapsed mode to keep only icons.</p>

<DemoComponentCard lang={'html'}>
  <div style="display: flex; gap: 1rem; height: 320px;">
    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
      <span class="text-label" style="font-size: 0.75rem; color: var(--color-on-surface-variant);">Expanded</span>
      <wc-navigation-rail mode="expanded" style="height: 100%; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
        <wc-navigation-rail-item active>
          <wc-icon slot="icon" name="home"></wc-icon>
          Home
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="search"></wc-icon>
          Search
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="bookmark"></wc-icon>
          Saved
        </wc-navigation-rail-item>
      </wc-navigation-rail>
    </div>

    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
      <span class="text-label" style="font-size: 0.75rem; color: var(--color-on-surface-variant);">Collapsed</span>
      <wc-navigation-rail mode="collapsed" style="height: 100%; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
        <wc-navigation-rail-item active>
          <wc-icon slot="icon" name="home"></wc-icon>
          Home
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="search"></wc-icon>
          Search
        </wc-navigation-rail-item>
        <wc-navigation-rail-item>
          <wc-icon slot="icon" name="bookmark"></wc-icon>
          Saved
        </wc-navigation-rail-item>
      </wc-navigation-rail>
    </div>
  </div>
</DemoComponentCard>

<h3>Collapsed Rail</h3>
<p>Collapsed mode keeps labels in markup for accessibility while hiding them visually.</p>

<DemoComponentCard lang={'html'}>
  <wc-navigation-rail mode="collapsed" style="height: 300px; border: 1px solid var(--color-outline-variant); border-radius: 1rem; overflow: hidden;">
    <wc-navigation-rail-item active>
      <wc-icon slot="icon" name="home"></wc-icon>
      Home
    </wc-navigation-rail-item>
    <wc-navigation-rail-item>
      <wc-icon slot="icon" name="search"></wc-icon>
      Search
    </wc-navigation-rail-item>
    <wc-navigation-rail-item>
      <wc-icon slot="icon" name="bookmark"></wc-icon>
      Saved
    </wc-navigation-rail-item>
    <wc-navigation-rail-item>
      <wc-icon slot="icon" name="settings"></wc-icon>
      Settings
    </wc-navigation-rail-item>
  </wc-navigation-rail>
</DemoComponentCard>
