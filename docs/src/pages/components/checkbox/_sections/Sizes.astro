---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<p class='text-body-large'>Checkboxes come in three sizes following Material Design 3 specifications: small (16px), medium (18px - default), and large (24px). All sizes include proper 40-48px touch targets for accessibility.</p>

<DemoComponentCard lang={'html'}>
  <wc-checkbox size='sm'>Small</wc-checkbox>
  <wc-checkbox size='md'>Medium (Default)</wc-checkbox>
  <wc-checkbox size='lg'>Large</wc-checkbox>
</DemoComponentCard>
