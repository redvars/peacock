---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
---
<pc-text type="body" expressive>Here are several predefined button styles, each serving its own semantic purpose. </pc-text>

<HighlighterCard lang={'html'}>
<wc-tab-group>
  <wc-tabs>
    <wc-tab>First tab</wc-tab>
    <wc-tab selected="true">Second tab</wc-tab>
    <wc-tab disabled>Disabled tab</wc-tab>
    <wc-tab>Last tab</wc-tab>
  </wc-tabs>

  <wc-tab-panel>
    <pc-text type="heading"> First tab content </pc-text>
  </wc-tab-panel>

  <wc-tab-panel>
    <pc-text type="heading"> Second tab content </pc-text>
  </wc-tab-panel>
</wc-tab-group>

<br />
<br />

<wc-tab-group>
  <wc-tabs>
    <wc-tab icon="home"></wc-tab>
    <wc-tab icon="circle--solid" selected="true">Circle</wc-tab>
    <wc-tab disabled icon="email">Email</wc-tab>
    <wc-tab icon="star--filled"></wc-tab>
  </wc-tabs>
</wc-tab-group>
</HighlighterCard>
