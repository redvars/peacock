---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<style is:inline>
  .demo-canvas .demo-area {
    height: 25rem;
  }
</style>
<DemoComponentCard lang={'html'} cssClasses='demo-canvas'>
<base-tabs>
  <tabs-list>
    <base-tab>First tab</base-tab>
    <base-tab active="true">Second tab</base-tab>
    <base-tab disabled>Disabled tab</base-tab>
    <base-tab href='https://shivajivarma.com'>External link</base-tab>
  </tabs-list>

  <base-tab-panel>
    <pc-text type="heading"> First content </pc-text>
  </base-tab-panel>

  <base-tab-panel>
    <pc-text type="heading"> Second content </pc-text>
  </base-tab-panel>
</base-tabs>
</DemoComponentCard>
