---
import DemoComponentCard from '../../../../components/DemoComponentCard.astro';
---
<style is:inline>
  .demo-canvas .demo-area {
    height: 25rem;
  }
</style>

<DemoComponentCard lang={'html'} cssClasses='demo-canvas'>
  <wc-tab-group>
    <wc-tabs>
      <wc-tab>First tab</wc-tab>
      <wc-tab active="true">Second tab</wc-tab>
      <wc-tab disabled>Disabled tab</wc-tab>
      <wc-tab href='https://shivajivarma.com'>External link</wc-tab>
    </wc-tabs>

    <wc-tab-panel>
      <pc-text type="heading"> First content </pc-text>
    </wc-tab-panel>

    <wc-tab-panel>
      <pc-text type="heading"> Second content </pc-text>
    </wc-tab-panel>
  </wc-tab-group>
</DemoComponentCard>

<DemoComponentCard lang={'html'} cssClasses='demo-canvas'>
  <wc-tab-group>
    <wc-tabs variant="line-secondary">
      <wc-tab>First tab</wc-tab>
      <wc-tab active="true">Second tab</wc-tab>
      <wc-tab disabled>Disabled tab</wc-tab>
      <wc-tab href='https://shivajivarma.com'>External link</wc-tab>
    </wc-tabs>

    <wc-tab-panel>
      <pc-text type="heading"> First content </pc-text>
    </wc-tab-panel>

    <wc-tab-panel>
      <pc-text type="heading"> Second content </pc-text>
    </wc-tab-panel>
  </wc-tab-group>
</DemoComponentCard>
