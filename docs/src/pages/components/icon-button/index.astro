---
import Layout from '../../../layouts/LitComponent.astro';
import { getComponentDetails, getTextTag } from '../../../_data/getLitComponentDetails.ts';
import LitComponentApiPanel from '../../../components/LitComponentApiPanel.astro';

import UsageSection from './_sections/Usage.astro';
import SizesSection from './_sections/Sizes.astro';
import StatesSection from './_sections/States.astro';
import VariantsSection from './_sections/Variants.astro';
import ColorsSection from './_sections/Colors.astro';
import EventsSection from './_sections/Events.astro';
import IconSection from './_sections/Icon.astro';
import OverviewPanel from '../../../components/OverviewPanel.astro';

const componentDetails = getComponentDetails('icon-button');

const sections = [
  {
    'title': 'Usage',
    'Component': UsageSection,
  }, {
    'title': 'Variants',
    'Component': VariantsSection,
  }];
---
<Layout componentDetails={componentDetails}>
  <wc-tab-group class='page-tabs'>
    <wc-tabs>
      <wc-tab selected='true'>Overview</wc-tab>
      <wc-tab>API</wc-tab>
    </wc-tabs>
    <wc-tab-panel>
      <OverviewPanel  sections={sections} />
    </wc-tab-panel>
    <wc-tab-panel>
      <LitComponentApiPanel componentDetails={componentDetails} />
    </wc-tab-panel>
  </wc-tab-group>
</Layout>

