---
import Layout from '../../../layouts/LitComponent.astro';
import { getComponentDetails } from '../../../_data/getLitComponentDetails.ts';
import ApiPanel from '../../../components/LitApiPanel.astro';
import OverviewPanel from '../../../components/OverviewPanel.astro';

import UsageSection from './_sections/usage.astro';
import MonthViewSection from './_sections/month-view.astro';
import DayViewSection from './_sections/day-view.astro';

const componentDetails = getComponentDetails('calendar');

const sections = [{
  'title': 'Week View',
  'Component': UsageSection,
}, {
  'title': 'Month View',
  'Component': MonthViewSection,
}, {
  'title': 'Day View',
  'Component': DayViewSection,
}];
---

<Layout componentDetails={componentDetails}>
  <wc-tab-group class='page-tabs'>
    <wc-tabs>
      <wc-tab selected='true'>Overview</wc-tab>
      <wc-tab>API</wc-tab>
    </wc-tabs>
    <wc-tab-panel>
      <OverviewPanel sections={sections} />
    </wc-tab-panel>
    <wc-tab-panel>
      <ApiPanel componentDetails={componentDetails} />
    </wc-tab-panel>
  </wc-tab-group>
</Layout>
