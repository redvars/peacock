---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import MenuItems from './dropdown-menu.astro';
---

<HighlighterCard lang='html'>

  <pc-dropdown>
    <wc-button>
      <wc-icon slot='icon' name='menu'></wc-icon>
    </wc-button>

    <MenuItems/>
  </pc-dropdown>
</HighlighterCard>

<HighlighterCard lang='html'>
  <pc-dropdown id='dropdown' placements='bottom-end'>
    <wc-button variant='text'><wc-icon slot='icon' name='menu'/></wc-button>

    <MenuItems/>
  </pc-dropdown>
</HighlighterCard>

