---
import HighlighterCard from '../../../../components/HighlighterCard.astro';
import MenuItems from './dropdown-menu.astro';
---

<HighlighterCard lang='html'>

  <pc-dropdown>
    <base-button>
      <base-icon slot='icon' name='menu'></base-icon>
    </base-button>

    <MenuItems/>
  </pc-dropdown>
</HighlighterCard>

<HighlighterCard lang='html'>
  <pc-dropdown id='dropdown' placements='bottom-end'>
    <base-button variant='text'><base-icon slot='icon' name='menu'/></base-button>

    <MenuItems/>
  </pc-dropdown>
</HighlighterCard>

