---
import Layout from '../../../layouts/Post.astro';
import '../../../styles/post.scss';
import site from '../../../_data/site.json';
export const title = `${site.title} 1.0`;
export const description = `Hi all! 👋 We are ${site.title}, a collective of open source and web component enthusiasts. We consider it our goal to empower everyone with a powerful and battle-tested setup for creating and sharing open source customizable web components.`;
export const publishedDate = "2023-08-03";
---
<Layout title={title} description={description}>
  <p class='text-body-large'>
    { description }
  </p>
</Layout>
