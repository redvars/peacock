---
import Layout from '../../layouts/Default.astro';
const allPosts = await Astro.glob('./posts/*.astro');
import '../../styles/blog.scss';
import site from '../../_data/site.json';
import Footer from '../../components/Footer.astro';
---
<Layout  classes='surface'>
  <div class='main-content'>
    <wc-container class='blog-posts page-container'>
      <h2 class='text-display'>Blog</h2>
      <p class='text-body-large'>News and announcements for all things { site.title }, including new releases</p>

      <wc-divider></wc-divider>

      <div class='post-list'>
        {allPosts.map(async (post: any) => {
          return (
            <div class='item'>
              <h3 class='text-headline'>
                <wc-link href={`${post.url}`} title='{{ post.title }}'>{post.title}</wc-link>
              </h3>
              <p class='text-body-large'>{post.description}</p>
              <pc-text color='secondary'>
                Posted on {post.publishedDate}
              </pc-text>
            </div>);
        })}

      </div>
    </wc-container>
    <Footer />
  </div>
</Layout>
