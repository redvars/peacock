---
interface Props {
  sections: any;
}

const { sections, title } = Astro.props;
---

<div class="section-nav">
  <div class="section-nav-content">

    <p class="text-body-large">On this page</p>
    <h2 class="text-headline">{title}</h2>
    <menu-list id="overview-navigation" variant="vibrant">
      {
        sections.map((section: any) => {
          const sectionValue = section.title.toLowerCase().replaceAll(' ', '-').replaceAll('/', '-');
          return <menu-item href={`#section-${sectionValue}`} value={sectionValue}>{section.title}</menu-item>
        })
      }
    </menu-list>

    <script>
      const overviewNavigation = document.getElementById('overview-navigation');

      const nodes = overviewNavigation?.querySelectorAll('menu-item');
      if (nodes?.length) {
        //@ts-ignore
        let selectedValue = location.hash?.replace("#section-", "");

        setTimeout(function() {
          selectNode(selectedValue)
        });

        nodes.forEach(function(node) {
            node.addEventListener('click', function() {
              nodes.forEach(function(node) {
              node.selected = false;
            });
              this.selected = true;
            })
          });
        
      }

      function selectNode(selectedValue) {
          const overviewNavigation = document.getElementById('overview-navigation');
          const nodes = overviewNavigation?.querySelectorAll('menu-item');

          if (selectedValue)
            nodes.forEach(function(node) {
              node.selected = node.value == selectedValue;
            });
          else
            nodes[0].selected = true;
      }
    </script>

    <ins class="adsbygoogle" data-ad-client="ca-pub-3120721550776061" data-ad-slot="1398164690" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
      const interval = window.setInterval(() => {
        if (window.document.documentElement.classList.contains('hydrated')) {
          window.clearInterval(interval);

          setTimeout(function () {
            const script = document.createElement('script');
            script.type = 'text/javascript';
            script.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3120721550776061';
            script.crossOrigin = 'anonymous';
            script.async = true;
            document.body.appendChild(script);
          }, 800);
        }
      }, 300);
    </script>
  </div>
</div>
